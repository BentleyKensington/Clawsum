# OpenRouter escalation + on-demand speech — copy vars into /docker/clawsum/.env
# See deploy/docs/OPENROUTER-AND-VOICE.md

# --- OpenRouter (non-OpenAI models only) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://clawsum.local
OPENROUTER_APP_TITLE=Clawsum

# Slugs without openrouter/ prefix — OpenClaw adds prefix automatically
OPENROUTER_ESCALATION_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_CODING_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_RESEARCH_MODEL=google/gemini-2.5-pro

# --- Speech on demand (scripts/speech_api.py + OpenClaw /tts) ---
SPEECH_STT_PROVIDER=openai
SPEECH_TTS_PROVIDER=openai

OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3

# Multimodal STT via OpenRouter (when SPEECH_STT_PROVIDER=openrouter)
OPENROUTER_STT_MODEL=google/gemini-2.5-flash

# Optional ElevenLabs TTS (set SPEECH_TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

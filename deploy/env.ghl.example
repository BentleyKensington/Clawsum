# GHL credentials (Clawsum VPS /docker/clawsum/.env)
# Copy relevant lines into .env when Boss provides PIT + locationId.
# MCP servers auto-enable when both PIT and LOCATION_ID are set.
# Never commit .env — see deploy/docs/CREDENTIALS-EXCLUSION.md

# --- Generic single-account template ---
GHL_PIT=pit-...
GHL_LOCATION_ID=
GHL_DB_PASSWORD=ghl_crm_change_me

# --- Multi-account instance overlay (REI example) ---
# See deploy/config/ghl-accounts.instance.rei.example.json
# GHL_MCO_REI_PIT=
# GHL_MCO_REI_LOCATION_ID=
# GHL_MCO_REI_DB_PASSWORD=

# After updating credentials:
#   python3 /docker/clawsum/scripts/provision-ghl-accounts.py
#   python3 /docker/clawsum/scripts/verify-ghl-isolation.py
#   cd /docker/clawsum && docker compose restart openclaw-gateway

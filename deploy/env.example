# Clawsum instance overlay — copy to /docker/clawsum/.env and fill per VPS.
# Never commit .env. See deploy/docs/PLATFORM-DEPLOY-TEMPLATE.md

# --- Core ---
POSTGRES_USER=clawsum
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=clawsum

OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.6.10
PAPERCLIP_IMAGE=ghcr.io/paperclipai/paperclip:latest

OPENCLAW_GATEWAY_PORT=48166
OPENCLAW_GATEWAY_TOKEN=generate_with_openssl_rand_hex_32
OPENCLAW_TZ=America/Chicago
OPENCLAW_CONFIG_DIR=./data/.openclaw
OPENCLAW_AUTH_PROFILE_SECRET_DIR=./data/.openclaw-auth-secrets

TRAEFIK_HOST=srv.example.com
BOSS_UI_HOST=boss.srv.example.com
OPENCLAW_UI_HOST=clawsum.srv.example.com
GRAFANA_UI_HOST=grafana.srv.example.com

# --- Paperclip / Boss UI ---
BETTER_AUTH_SECRET=generate_with_openssl_rand_hex_32
PAPERCLIP_PUBLIC_URL=https://boss.srv.example.com
PAPERCLIP_AGENT_JWT_SECRET=generate_with_openssl_rand_hex_32
OPENCLAW_GATEWAY_URL=http://127.0.0.1:48166

# Ops portal Traefik basic auth (see setup-ops-portal-traefik.sh)
BOSS_OPS_AUTH_USER=boss
BOSS_OPS_AUTH_PASSWORD=
OPENCLAW_TRUSTED_PROXY=true
HERMES_UI_HOST=hermes.srv.example.com
HERMES_DASHBOARD_PORT=9119

# Hermes cockpit plugin data feeds (optional — see examples/hermes-cockpit/README.md)
# CLAWSUM_BOSS_URL=https://boss.srv.example.com
# CLAWSUM_OPENCLAW_URL=https://clawsum.srv.example.com
# CLAWSUM_GRAFANA_URL=https://grafana.srv.example.com
# CLAWSUM_GRAFANA_EMBED_URL=https://grafana.srv.example.com/d/clawsum-health?orgId=1&kiosk

# --- Paperclip instance IDs (generate per VPS — never commit real values) ---
PAPERCLIP_COMPANY_ID=

# --- Telegram (optional — set per instance) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_REPORT_CHAT_ID=
TELEGRAM_PAPERCLIP_GROUP_ID=
TELEGRAM_ADMIN_CHAT_ID=
# Gmail OAuth failure alerts use ADMIN then REPORT then openclaw admin group fallback
# GMAIL_OAUTH_ALERT_COOLDOWN_HOURS=6


# --- GHL Telegram override (optional) ---
# GHL_TELEGRAM_GROUP_ID=

# --- LLM (optional — agents prefer Codex OAuth via Control UI) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- OpenRouter + speech (optional) — see env.openrouter-voice.example ---
# OPENROUTER_API_KEY=
# SPEECH_STT_PROVIDER=openai
# SPEECH_TTS_PROVIDER=openai

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=change_me

# --- ArcadeDB ---
ARCADEDB_ROOT_PASSWORD=change_me

# --- MinIO (Tier 2 — storage profile) ---
MINIO_ROOT_USER=clawsum
MINIO_ROOT_PASSWORD=change_me

# --- Gmail pack (optional) — see env.gmail.example ---
# GOG / OAuth vars

# --- GHL pack (optional) — see env.ghl.example ---
# GHL_PIT=
# GHL_LOCATION_ID=
# GHL_DB_PASSWORD=

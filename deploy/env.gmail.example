# Gmail admin inbox — add these to /docker/clawsum/.env after OAuth setup
GMAIL_ADMIN_ADDRESS=clawsums@gmail.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_BACKFILL_MAX=2000
GMAIL_SYNC_QUERY=in:all
GMAIL_INCREMENTAL_QUERY=newer_than:2d

# OpenClaw gog skill (Control UI + agent Gmail tools)
GOG_KEYRING_BACKEND=file
GOG_KEYRING_PASSWORD=
